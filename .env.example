# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# ---------------------------------------------------------------------------
# LLM provider order (comma-separated).
# The bot tries providers left-to-right, falling back automatically on errors.
# Remove a provider name if you have not configured an API key for it.
# ---------------------------------------------------------------------------
LLM_PROVIDER_ORDER=openrouter,gemini,groq

# ---------------------------------------------------------------------------
# OpenRouter  –  https://openrouter.ai/keys
# Free tier: many free models available (e.g. meta-llama/llama-3-8b-instruct:free)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model to use (default: openai/gpt-4o-mini)
# Free-tier choices: openai/gpt-4o-mini, meta-llama/llama-3-8b-instruct:free, google/gemma-3-12b-it:free
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# Google Gemini  –  https://aistudio.google.com/app/apikey
# Free tier: generous RPM/RPD limits with gemini-1.5-flash at no cost
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------------------------
# Groq  –  https://console.groq.com/keys
# Free tier: rate-limited access to open-source models at no cost
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
# Model to use (default: llama3-8b-8192)
# Other free options: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama3-8b-8192

# ---------------------------------------------------------------------------
# LLM routing / retry tuning  (change these to match your free-tier limits)
# ---------------------------------------------------------------------------
# Maximum retry attempts per provider before falling back to the next one.
LLM_RETRY_MAX=3
# Base delay (seconds) for exponential back-off between retries.
LLM_RETRY_BASE_SECONDS=1.0
# Number of consecutive failures before a provider's circuit breaker opens.
LLM_CB_FAILURE_THRESHOLD=3
# Seconds a tripped circuit breaker stays open before re-allowing attempts.
LLM_CB_RECOVERY_SECONDS=60
